{
  "name": "@devify/ui",
  "version": "0.2.0",
  "description": "HTML Web Component library with design tokens, HTMX patterns, and PWA support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devify-me/devify-ui.git"
  },
  "homepage": "https://devify.me",
  "keywords": [
    "web-components",
    "custom-elements",
    "design-tokens",
    "htmx",
    "pwa",
    "zero-build",
    "light-dom"
  ],
  "files": [
    "devify.css",
    "devify.js",
    "page-transition.css",
    "components/",
    "patterns/",
    "tokens/",
    "dist/",
    "custom-elements.json"
  ],
  "exports": {
    ".": {
      "default": "./devify.js"
    },
    "./devify.css": "./devify.css",
    "./devify.js": "./devify.js",
    "./page-transition.css": "./page-transition.css",
    "./components/*": "./components/*",
    "./patterns/*": "./patterns/*",
    "./tokens/*": "./tokens/*"
  },
  "main": "./devify.js",
  "style": "./devify.css",
  "devDependencies": {
    "@open-wc/eslint-config": "^13.0.0",
    "@open-wc/testing": "^4.0.0",
    "@web/test-runner": "^0.20.2",
    "@web/test-runner-playwright": "^0.11.1",
    "esbuild": "^0.27.4",
    "eslint": "^10.1.0",
    "playwright": "^1.58.2",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "web-component-analyzer": "^2.0.0"
  },
  "scripts": {
    "analyze": "wca analyze components/ patterns/ --format json --outFile custom-elements.json",
    "serve": "python3 -m http.server 8090",
    "contrast": "node scripts/check-contrast.js",
    "contrast:ci": "node scripts/check-contrast.js --ci",
    "themes:gen": "node scripts/generate-named-theme.mjs",
    "themes:check": "node scripts/generate-named-theme.mjs --check",
    "check:tokens": "node scripts/check-no-hardcoded.mjs --ci",
    "check:dvfy-pref": "node scripts/check-dvfy-preference.mjs --ci",
    "lint": "npm run lint:js && npm run lint:css && npm run check:tokens && npm run check:dvfy-pref",
    "lint:js": "eslint components/ patterns/ catalog/ tokens/ scripts/",
    "lint:css": "stylelint 'tokens/**/*.css'",
    "test": "web-test-runner",
    "test:watch": "web-test-runner --watch",
    "verify:composition": "node scripts/verify-composition-demo.mjs",
    "verify:button-href": "node scripts/verify-button-href.mjs",
    "build": "node scripts/build.js"
  }
}
