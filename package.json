{
  "name": "@devify/ui",
  "version": "0.1.0",
  "description": "HTML Web Component library with design tokens, HTMX patterns, and PWA support",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/devify-me/devify-ui.git"
  },
  "homepage": "https://devify.me",
  "keywords": [
    "web-components",
    "custom-elements",
    "design-tokens",
    "htmx",
    "pwa",
    "zero-build",
    "light-dom"
  ],
  "files": [
    "devify.css",
    "devify.js",
    "components/",
    "patterns/",
    "tokens/"
  ],
  "exports": {
    ".": {
      "default": "./devify.js"
    },
    "./devify.css": "./devify.css",
    "./devify.js": "./devify.js",
    "./components/*": "./components/*",
    "./patterns/*": "./patterns/*",
    "./tokens/*": "./tokens/*"
  },
  "main": "./devify.js",
  "style": "./devify.css",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@web/test-runner": "^0.20.2",
    "axe-playwright": "^2.2.2",
    "eslint": "^10.1.0",
    "eslint-plugin-no-unsanitized": "^4.1.5",
    "playwright": "^1.58.2",
    "wait-on": "^9.0.4",
    "web-component-analyzer": "^2.0.0"
  },
  "scripts": {
    "analyze": "wca analyze components/ patterns/ --format json --outFile custom-elements.json",
    "serve": "python3 -m http.server 8090",
    "lint": "eslint components/ patterns/",
    "test": "web-test-runner",
    "a11y": "node test/a11y.js"
  }
}
